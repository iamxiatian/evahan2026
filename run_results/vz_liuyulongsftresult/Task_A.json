[
    {
        "image_path": "Task_A/a_001.jpg",
        "text": "龍門建極宮記"
    },
    {
        "image_path": "Task_A/a_002.jpg",
        "text": "而豺虎息物焉而疵癘不起民焉而災孽不生神之聽之介爾景"
    },
    {
        "image_path": "Task_A/a_003.jpg",
        "text": "事人名然無姓可稽付之缺如"
    },
    {
        "image_path": "Task_A/a_004.jpg",
        "text": "案此石第有書銜而無撰文立石之名文內貴字小寫顯係主"
    },
    {
        "image_path": "Task_A/a_005.jpg",
        "text": "開山嗣講道士碧□子何應和書"
    },
    {
        "image_path": "Task_A/a_006.jpg",
        "text": "聞諸先儒法始乎伏羲而傳乎堯堯以是傳"
    },
    {
        "image_path": "Task_A/a_007.jpg",
        "text": "間計四十椽西廊九間計三十六椽緘膳廳三間計一十四椽厨"
    },
    {
        "image_path": "Task_A/a_008.jpg",
        "text": "事意無得騷擾安下及隣右人等亦不得將府學房舍四至地基"
    },
    {
        "image_path": "Task_A/a_009.jpg",
        "text": "日久官司占作廨字或隣右人等侵占乞給付公據事相府准呈"
    },
    {
        "image_path": "Task_A/a_010.jpg",
        "text": "西至泮濠南至城巷北至王通判宅四至内地土及房舍誠恐"
    },
    {
        "image_path": "Task_A/a_011.jpg",
        "text": "軍馬無得於廟宇內安下或聚集理問詞訟及褻瀆飲宴管工匠"
    },
    {
        "image_path": "Task_A/a_012.jpg",
        "text": "時致祭諸儒月朔釋奠宜恒令洒掃淸潔今後禁約諸官員使臣"
    },
    {
        "image_path": "Task_A/a_013.jpg",
        "text": "今給公據付府學收執仍仰諸官府幷使臣軍匠人等欽依聖旨"
    },
    {
        "image_path": "Task_A/a_014.jpg",
        "text": "擾使臣安下欽此卑職切見府學成德堂書院地土四至東至廟"
    },
    {
        "image_path": "Task_A/a_015.jpg",
        "text": "官不得於其中營造違者治罪管內凡有書院亦不得令諸人騷"
    },
    {
        "image_path": "Task_A/a_016.jpg",
        "text": "管民官管匠人打捕諸頭目及諸軍馬使臣人等宣聖廟國家歲"
    },
    {
        "image_path": "Task_A/a_017.jpg",
        "text": "侵占須諭出給公據者"
    },
    {
        "image_path": "Task_A/a_018.jpg",
        "text": "一成德堂七間計五十六椽東廊二十"
    },
    {
        "image_path": "Task_A/a_019.jpg",
        "text": "昌呈照得先領奉聖旨節文道與陝西等路宣撫司幷達魯花赤"
    },
    {
        "image_path": "Task_A/a_020.jpg",
        "text": "間計一十二椽小舍三間計六椽　右給付京兆路府學收執准"
    },
    {
        "image_path": "Task_A/a_021.jpg",
        "text": "此蒙字一行至元十三年十二月十三日"
    },
    {
        "image_path": "Task_A/a_022.jpg",
        "text": "西舍三間計六椽又舍二間計六椽土地堂一間計三椽門東舍"
    },
    {
        "image_path": "Task_A/a_023.jpg",
        "text": "房三間計二十椽勃海舍三間計六椽門屋三間計一十二椽門"
    },
    {
        "image_path": "Task_A/a_024.jpg",
        "text": "等房產所謂凡有血氣者莫不尊親不謂近日動云廢孔無論"
    },
    {
        "image_path": "Task_A/a_025.jpg",
        "text": "案元以外蒙入主中土猶知加聖號修孔廟幷保護管內書院"
    },
    {
        "image_path": "Task_A/a_026.jpg",
        "text": "其不知量亦不知自居何等矣其房屋內勃海舍三字未審何"
    },
    {
        "image_path": "Task_A/a_027.jpg",
        "text": "二椽門屋一間計二椽　西院正堂七間計四十一椽厨房三"
    },
    {
        "image_path": "Task_A/a_028.jpg",
        "text": "二間計八椽又舊舍三間計一十二椽　采芹堂七間計四十"
    },
    {
        "image_path": "Task_A/a_029.jpg",
        "text": "夕夢仙娃衣靑衣冠𤣥冠授桃一枚食而有娠辛巳季冬載弄之"
    },
    {
        "image_path": "Task_A/a_030.jpg",
        "text": "翛然足蹈龜文手過於膝不好與同稚嬉戲方七歲𤣥逸張眞人"
    },
    {
        "image_path": "Task_A/a_031.jpg",
        "text": "其姓德用其名容輔其字鑑峯其號也家世雍之右族母陳氏翼"
    },
    {
        "image_path": "Task_A/a_032.jpg",
        "text": "淸之玉版勳昭太𤣥之金籙者烏能與於此洞陽公其人矣公井"
    },
    {
        "image_path": "Task_A/a_033.jpg",
        "text": "奉朝命祀岳瀆適秦甸其父携而見之眞人撫其頂曰此子神韻"
    },
    {
        "image_path": "Task_A/a_034.jpg",
        "text": "夕霞彩奪目淸香襲人智者以爲仙人謫降之意生而寡語動靜"
    },
    {
        "image_path": "Task_A/a_035.jpg",
        "text": "毓秀鍾乎貞淑腹全九丹身輕孤鶩呼吸沆瀣咀嚼芝茯名列玉"
    },
    {
        "image_path": "Task_A/a_036.jpg",
        "text": "於沃焦暮晞首於暘谷高揖閬風長嘯崐麓若非誕靈禀乎淸和"
    },
    {
        "image_path": "Task_A/a_037.jpg",
        "text": "太樸之隩比飛廉而擁六龍之車呵烈缺而從二馬之轂朝濯髦"
    },
    {
        "image_path": "Task_A/a_038.jpg",
        "text": "而不受塵攖滌玄覽而弗令慾縮探混茫於太素之先窺鴻濛於"
    },
    {
        "image_path": "Task_A/a_039.jpg",
        "text": "卜花篆額聞夫眞人者官天地府萬物誠意心遺耳目解帝懸"
    },
    {
        "image_path": "Task_A/a_040.jpg",
        "text": "監察御史眞聖奴書丹　大中大夫陝西奉元路達魯花赤呵剌"
    },
    {
        "image_path": "Task_A/a_041.jpg",
        "text": "值異人授以三洞秘訣九淸隱文屬曰子能退藏於密心誦力行"
    },
    {
        "image_path": "Task_A/a_042.jpg",
        "text": "澍公曰民罹其菑不允所請吾其虎狼耶遂諾之於上章之際卿"
    },
    {
        "image_path": "Task_A/a_043.jpg",
        "text": "月道士張道淸偕異人請修羅天上章大醮一千二百分以禱甘"
    },
    {
        "image_path": "Task_A/a_044.jpg",
        "text": "雨福國利民亦其餘事矣勉之勉之明年美原民苦旱魃之虐三"
    },
    {
        "image_path": "Task_A/a_045.jpg",
        "text": "他日席鮫鯨而游汗漫騎風鶴而登太淸不爲難矣如謂禱祈陽"
    },
    {
        "image_path": "Task_A/a_046.jpg",
        "text": "和苗眞君金章法旨召詣天亰授諸路道敎所幕官納爲弟子方"
    },
    {
        "image_path": "Task_A/a_047.jpg",
        "text": "通年甫弱冠夤奉亦隣眞大臣令旨護持再二年承特進神仙凝"
    },
    {
        "image_path": "Task_A/a_048.jpg",
        "text": "誠子師矣初不介意敎以經書洞曉大義旁及星緯之學無不該"
    },
    {
        "image_path": "Task_A/a_049.jpg",
        "text": "几杖執巾瓶爲童子事尊師曰吾焉能爲子師他日東方半萬翁"
    },
    {
        "image_path": "Task_A/a_050.jpg",
        "text": "辭一親禮耀州之五臺山伏魯子韓眞人之孫冉尊師爲弟子負"
    },
    {
        "image_path": "Task_A/a_051.jpg",
        "text": "沖粹他日當爲仙林之冠冕遂付道德經令讀之如夙昔所熟後"
    },
    {
        "image_path": "Task_A/a_052.jpg",
        "text": "師領諸路道教都提點仍署嵩山中岳廟住持提點兼奉元者皇"
    },
    {
        "image_path": "Task_A/a_053.jpg",
        "text": "賁幣集九路提點詣山請公疏略曰錦軸如開早發趣裝之興靑"
    },
    {
        "image_path": "Task_A/a_054.jpg",
        "text": "者數四公固泉石之懷猿鶴之戀卒不與起次歲秋復差官馳疏"
    },
    {
        "image_path": "Task_A/a_055.jpg",
        "text": "後公歸五臺蘭佩莎褧以償煙霞之癖己卯完顔大宗師請輔敎"
    },
    {
        "image_path": "Task_A/a_056.jpg",
        "text": "于上請敕翰林詞臣製文勒石垂示悠久歐陽玄拜命潤色之是"
    },
    {
        "image_path": "Task_A/a_057.jpg",
        "text": "以廣厥宇不一霜奐然一新右丞相脫脫左丞相帖木爾不花言"
    },
    {
        "image_path": "Task_A/a_058.jpg",
        "text": "凝和於覃懷復掌敎之一年召委重化璽書授洞陽顯道忠貞大"
    },
    {
        "image_path": "Task_A/a_059.jpg",
        "text": "武靖王以師事之上洞陽顯道之稱天曆始元文宗入承大寳起"
    },
    {
        "image_path": "Task_A/a_060.jpg",
        "text": "道價靄然聲馳王邸至治改元大哥赤荆王贈洞陽眞人號鎮西"
    },
    {
        "image_path": "Task_A/a_061.jpg",
        "text": "后懿旨特賜御香代薦其誠抵嵩岳修金籙大醮以祝天壽尋視"
    },
    {
        "image_path": "Task_A/a_062.jpg",
        "text": "雲繚繞瑞氣氤氲終瀉天瓢者三晝宵是歲大登若斯者衆繇是"
    },
    {
        "image_path": "Task_A/a_063.jpg",
        "text": "廟宇陵夷遂建言河南行中書省咨請聞上上俞之出太府金幣"
    },
    {
        "image_path": "Task_A/a_064.jpg",
        "text": "默誠良久而命之仍飭蓋臣設祖帳給驛騎而行抵宮代禮行香"
    },
    {
        "image_path": "Task_A/a_065.jpg",
        "text": "產錢粮昏湮者理之霞館芝房未有者剏之儀矩規繩紊亂者振"
    },
    {
        "image_path": "Task_A/a_066.jpg",
        "text": "祝延亦如嵩岳故事住持不數載宮中崇殿不堂隳圯者新之恒"
    },
    {
        "image_path": "Task_A/a_067.jpg",
        "text": "都提點洞陽顯道忠貞道人俾總宮事詔赴便殿錫御香上奉函"
    },
    {
        "image_path": "Task_A/a_068.jpg",
        "text": "君高弟披雲宋天師嫡孫秉彜高潔可被登庸奉旨授諸路道敎"
    },
    {
        "image_path": "Task_A/a_069.jpg",
        "text": "重陽萬壽宮係重陽輔極帝君修道之區先君降龍衣永鎭之所"
    },
    {
        "image_path": "Task_A/a_070.jpg",
        "text": "邇來典者失人廢幾不振選道價淸高者命一云奏公係凝和苗眞"
    },
    {
        "image_path": "Task_A/a_071.jpg",
        "text": "雲狎麋鹿逍遙乎不貸之圗衣冠之選非臣所思力辭不就是以"
    },
    {
        "image_path": "Task_A/a_072.jpg",
        "text": "愛還授公集賢大學士公奏曰臣草莽野服嵓阿槁夫志在臥白"
    },
    {
        "image_path": "Task_A/a_073.jpg",
        "text": "上問以惜身保命之術公對以誠心執中之道妙沃上心大加器"
    },
    {
        "image_path": "Task_A/a_074.jpg",
        "text": "山若戀恐招懷寳之譏辭不已而起之抵長春宮明日朝覲至尊"
    },
    {
        "image_path": "Task_A/a_075.jpg",
        "text": "上愈愛之明年旨給駝馬隨幸上京值都堂大臣議陝西勅賜大"
    },
    {
        "image_path": "Task_A/a_076.jpg",
        "text": "翥官吏都氓瞻拭者莫不驚訝弔誄之士素車白馬楮幢禋簋隱"
    },
    {
        "image_path": "Task_A/a_077.jpg",
        "text": "肱而化遲明仙鶴百餘摩雲而至口遶移時一鶴戛然長鳴而北"
    },
    {
        "image_path": "Task_A/a_078.jpg",
        "text": "奏淸樂歌步虛詞更將四鼓但覺天風灑然清香靄然公就榻曲"
    },
    {
        "image_path": "Task_A/a_079.jpg",
        "text": "機吾將與汝偕徂歸須臾其雀西舉是夜集童子幷冠者六七人"
    },
    {
        "image_path": "Task_A/a_080.jpg",
        "text": "擊節而歌曰白雀白雀世所希來從何所相參飛不須龜筮以見"
    },
    {
        "image_path": "Task_A/a_081.jpg",
        "text": "之容癸未秋公有還山之興陝西行中書省差官齎茶禮以留鶴"
    },
    {
        "image_path": "Task_A/a_082.jpg",
        "text": "皆其淸望之士公以尙綱不固文章人服遂□歸五臺枕石漱流"
    },
    {
        "image_path": "Task_A/a_083.jpg",
        "text": "馭越明年謂衆曰世事無涯人生有涯以有涯隨無涯可乎衆未"
    },
    {
        "image_path": "Task_A/a_084.jpg",
        "text": "豁晦名迹逮至正戊子二月初八日忽有白雀二翼舞於庭下公"
    },
    {
        "image_path": "Task_A/a_085.jpg",
        "text": "及對公毅然曰名遂功成無落吾志遂攜一童一負老莊義易一"
    },
    {
        "image_path": "Task_A/a_086.jpg",
        "text": "負簑笠缾盂拽杖而出詣磻溪悞遯聞其風而致詞貽物者忽口"
    },
    {
        "image_path": "Task_A/a_087.jpg",
        "text": "之居常湖海之士請益者泛泛而至公必肅□而接未嘗有倨傲"
    },
    {
        "image_path": "Task_A/a_088.jpg",
        "text": "返九還之功全矣舉柩飄然不因人力亦足以知仙凡之不侔矣"
    },
    {
        "image_path": "Task_A/a_089.jpg",
        "text": "玲瓏雲杉月檜摩蒼穹眞人仙蜕藏其崇眞人爲誰容輔翁道術"
    },
    {
        "image_path": "Task_A/a_090.jpg",
        "text": "倒置之徒同日而語哉惜乎予無七步之才焉敢玷萬年之石辭"
    },
    {
        "image_path": "Task_A/a_091.jpg",
        "text": "仙鶴來迎清香浮動亦足以知朝元始而拜虛皇矣安可與顓蒙"
    },
    {
        "image_path": "Task_A/a_092.jpg",
        "text": "見誇予喟然應之曰眞人仙去朱顔不改四體柔和亦足以知七"
    },
    {
        "image_path": "Task_A/a_093.jpg",
        "text": "子史羅胸中丹宸入對沃帝聰隆加優渥聲名雄金書俾主重陽"
    },
    {
        "image_path": "Task_A/a_094.jpg",
        "text": "不獲已而次第之系之以詞曰"
    },
    {
        "image_path": "Task_A/a_095.jpg",
        "text": "教席至則終以二九執事者但陳錦幣宣疏軸奠祭而還門人入"
    },
    {
        "image_path": "Task_A/a_096.jpg",
        "text": "昇仙臺是時𤣥敎大宗師關眞人遣官持疏致幣請赴京師嗣以"
    },
    {
        "image_path": "Task_A/a_097.jpg",
        "text": "壙輕若無人啟函視之朱顔不改四體不殭亦異矣藏諸本山之"
    },
    {
        "image_path": "Task_A/a_098.jpg",
        "text": "室者焦德潤薦奉議大夫乾州知州曹完澤所述行實踵門以文"
    },
    {
        "image_path": "Task_A/a_099.jpg",
        "text": "隱然塞乎道途若有所不勝亦其景行之所感也越七日舉棺就"
    },
    {
        "image_path": "Task_A/a_100.jpg",
        "text": "鑑峯之西泥陽東昇仙臺峙盤"
    },
    {
        "image_path": "Task_A/a_101.jpg",
        "text": "善歸全躬翩翩白鶴翔天風鞭敦圍兮笞靈霞乘雲氣兮衝寒空"
    },
    {
        "image_path": "Task_A/a_102.jpg",
        "text": "蘊奧弘仁廣義大眞人掌管諸路道敎所知集賢院道敎事完顏"
    },
    {
        "image_path": "Task_A/a_103.jpg",
        "text": "潤本宮提點洞和明道崇眞大師楊德榮等建　特進神仙重𤣥"
    },
    {
        "image_path": "Task_A/a_104.jpg",
        "text": "九日門人奉元路大重陽萬壽宮提點仁明弘義洞元大師焦德"
    },
    {
        "image_path": "Task_A/a_105.jpg",
        "text": "宮百廢皆舉驚神工峨冠揮麈折異同志與後覺開盲龍其生也"
    },
    {
        "image_path": "Task_A/a_106.jpg",
        "text": "碑上層爲二端圖下刻記二瑞者嘉禾歧麥也圖刻甚工惜文"
    },
    {
        "image_path": "Task_A/a_107.jpg",
        "text": "丹文銘石臺之崧名垂萬古聲無窮"
    },
    {
        "image_path": "Task_A/a_108.jpg",
        "text": "至正八年歲舍戊子九月"
    },
    {
        "image_path": "Task_A/a_109.jpg",
        "text": "德明杜養榮刻"
    },
    {
        "image_path": "Task_A/a_110.jpg",
        "text": "與字俱不佳恐不足以傳遠耳"
    },
    {
        "image_path": "Task_A/a_111.jpg",
        "text": "畢氏關中金石記"
    },
    {
        "image_path": "Task_A/a_112.jpg",
        "text": "石高五尺五寸廣二尺二寸分兩截上截爲圖下截爲記何恭"
    },
    {
        "image_path": "Task_A/a_113.jpg",
        "text": "撰文傅夢臣正書並篆額題雙瑞之圖四字篆書在西安碑"
    },
    {
        "image_path": "Task_A/a_114.jpg",
        "text": "負仍引斜谷之水𣴑田千有餘畝使縣民永被其澤遣壯士晝夜"
    },
    {
        "image_path": "Task_A/a_115.jpg",
        "text": "之日促車而行惠及於民民請文爲久思之計不賢者能如是乎"
    },
    {
        "image_path": "Task_A/a_116.jpg",
        "text": "役常平有法引水溉田以潤斯民不可謂不能也公之歸也解印"
    },
    {
        "image_path": "Task_A/a_117.jpg",
        "text": "雨民不凍餒設學校興禮遜息民詞可不謂之能乎禁強暴均賦"
    },
    {
        "image_path": "Task_A/a_118.jpg",
        "text": "守把巡護以警不虞內外得以安謐嗚呼公之來也督農柔感時"
    },
    {
        "image_path": "Task_A/a_119.jpg",
        "text": "手中無苞苴之行前後輸粟數萬餘石而民了無一語以陳其偏"
    },
    {
        "image_path": "Task_A/a_120.jpg",
        "text": "余曰官得其人而百事舉良因此夫至正十有四年秋九月蒙秦"
    },
    {
        "image_path": "Task_A/a_121.jpg",
        "text": "粟軍儲公第分九等均派於民禁委吏輿臺之徒而不敢高下其"
    },
    {
        "image_path": "Task_A/a_122.jpg",
        "text": "時適興元金翔以及江漢群盜竊弄干戈申給關隘丁壯每遇運"
    },
    {
        "image_path": "Task_A/a_123.jpg",
        "text": "來攘□公設以方術必獲刑之兩遇亢陽遍禱於神甘霖霈作百"
    },
    {
        "image_path": "Task_A/a_124.jpg",
        "text": "化愚民以修孝弟禮遜之風漸興盜賊因自而息縱別境之徒潛"
    },
    {
        "image_path": "Task_A/a_125.jpg",
        "text": "穀皆登易爲豐歲家家得以安飽□常平倉粟四千餘斛挑□□"
    },
    {
        "image_path": "Task_A/a_126.jpg",
        "text": "琇□□□儒飾吏下及吏□大小熙和凡事咸贊成之視他邑之"
    },
    {
        "image_path": "Task_A/a_127.jpg",
        "text": "明等立石石工張文通張敏中刋"
    },
    {
        "image_path": "Task_A/a_128.jpg",
        "text": "以傳之不朽故爲缺書至正十有五年歲次乙未正月日劉思"
    },
    {
        "image_path": "Task_A/a_129.jpg",
        "text": "治民言行與公相孚冬十月王德義尹代其公簿王申福典史李"
    },
    {
        "image_path": "Task_A/a_130.jpg",
        "text": "省以國調遣之急選前豐備總庫提領養安處來□是邑尤長於"
    },
    {
        "image_path": "Task_A/a_131.jpg",
        "text": "選爲前尹鄕之耆艾劉思明等慕公之恩懷公之政請文刋諸石"
    },
    {
        "image_path": "Task_A/a_132.jpg",
        "text": "研齋筆記期頤篆跡渾樸高古以禹碑周鼓爲宗無一筆似陽"
    },
    {
        "image_path": "Task_A/a_133.jpg",
        "text": "書史會要期頤字子奇汴梁人官至陝西行臺治書工於篆六"
    },
    {
        "image_path": "Task_A/a_134.jpg",
        "text": "義門王氏先塋碑"
    },
    {
        "image_path": "Task_A/a_135.jpg",
        "text": "至正十五年"
    },
    {
        "image_path": "Task_A/a_136.jpg",
        "text": "原石已佚歐陽立撰文危素正書趙期頤篆額原在滿城縣"
    },
    {
        "image_path": "Task_A/a_137.jpg",
        "text": "政鮮有及焉公名鈞字平叔朝邑人由儒□□□職轉陞儒林□"
    },
    {
        "image_path": "Task_A/a_138.png",
        "text": "無所不愼焉嘗相魯衛卒于齊明于愼行曰史遷"
    },
    {
        "image_path": "Task_A/a_139.jpg",
        "text": "如此母性恇雷霆未聞輒掩耳每聞虺虺聲繞墓躬步履事死如"
    },
    {
        "image_path": "Task_A/a_140.jpg",
        "text": "同體人唯不知孝頑然自痿痺母死喪未歛東隣忽火起伏牀撫"
    },
    {
        "image_path": "Task_A/a_141.jpg",
        "text": "文信磊落豪傑士生平不讀書所行多中理曰此蔡孝子吾鄕之"
    },
    {
        "image_path": "Task_A/a_142.jpg",
        "text": "事生聖賢著乎禮嗟此事死心聖賢同一揆迄今幾何年四海談"
    },
    {
        "image_path": "Task_A/a_143.jpg",
        "text": "屍哭忍死不欲避倏爾熾西家異事驚遠邇勿謂天居高神速乃"
    },
    {
        "image_path": "Task_A/a_144.jpg",
        "text": "桃李不旦只生還又奉以肉米良心天地心人人固應爾順嘗出"
    },
    {
        "image_path": "Task_A/a_145.jpg",
        "text": "所得具詢其所以春風靄山林和氣溢肝肺鳴梟化鸞凰荆棘變"
    },
    {
        "image_path": "Task_A/a_146.jpg",
        "text": "古人亦以勸頑鄙爾曹墾者誰吾欲與從事田氓恥前非俛首爲"
    },
    {
        "image_path": "Task_A/a_147.jpg",
        "text": "盛軌誰家無子孫欲俾恒瞻視吾家數十年拜掃同考妣非惟愛"
    },
    {
        "image_path": "Task_A/a_148.jpg",
        "text": "不已丘隴尙依然神迹豈容圯近爲農所夷見者恬不異石泉王"
    },
    {
        "image_path": "Task_A/a_149.jpg",
        "text": "甘旨黑者以供母赤者以啓己至孝存乎心家寒聽菽水偶爲賊"
    },
    {
        "image_path": "Task_A/a_150.jpg",
        "text": "樵蘇半途驚心悸拾薪即歸來客至母噬指呼吸氣相通親與子"
    },
    {
        "image_path": "Task_A/a_151.jpg",
        "text": "載餘義猶不令毁欲使澆風淳高識顧不美賦此五言詩用當以"
    },
    {
        "image_path": "Task_A/a_152.jpg",
        "text": "仰止旣云孝子里其來必有自我許王君心是非烏足計荒墳千"
    },
    {
        "image_path": "Task_A/a_153.jpg",
        "text": "仲義崆峒與綿田亦復疑一一河東乃山西或云在隴坻武侯八"
    },
    {
        "image_path": "Task_A/a_154.jpg",
        "text": "密畤南陵有孝陵得名或此始于曰皆不然今將排衆議地望雖"
    },
    {
        "image_path": "Task_A/a_155.jpg",
        "text": "琬琰永使耕者忌非文無以傳先生爲僕記或云蔡君仲其鄕非"
    },
    {
        "image_path": "Task_A/a_156.jpg",
        "text": "封壙文信翬謂予吾力勸吾世諸男豚犬然他時不足恃僕將刻"
    },
    {
        "image_path": "Task_A/a_157.jpg",
        "text": "陣圖川蜀有三四先正廟天下處處嚴祭祀茍在鄕閭中其民各"
    },
    {
        "image_path": "Task_A/a_158.jpg",
        "text": "異同人事有遷徙安知汝南人不向關中死未必孝陵名不取君"
    },
    {
        "image_path": "Task_A/a_159.jpg",
        "text": "又按元代石刻亦夥惟文字佳者不過十分之五故擇犖犖大"
    },
    {
        "image_path": "Task_A/a_160.jpg",
        "text": "按此墓表前半爲文第叙立碑緣起後幅登載此詩叙孝子生"
    },
    {
        "image_path": "Task_A/a_161.jpg",
        "text": "平詳悉曉暢可以風世文欠雅潔故删文而錄其詩"
    },
    {
        "image_path": "Task_A/a_162.jpg",
        "text": "者登錄之無可傳者槪行删弃以省篇幅"
    },
    {
        "image_path": "Task_A/a_163.jpg",
        "text": "編纂渭南武樹善"
    },
    {
        "image_path": "Task_A/a_164.jpg",
        "text": "崇靈觀碑記存"
    },
    {
        "image_path": "Task_A/a_165.jpg",
        "text": "映實人間之奧區關中之佳境也主觀道士去來無定不可枚舉"
    },
    {
        "image_path": "Task_A/a_166.jpg",
        "text": "雲山之秀拔樹林之蔽虧風土高爽原隰饒沃麻麥錯布桑棗交"
    },
    {
        "image_path": "Task_A/a_167.jpg",
        "text": "相見曰二子素聞吾友嘗從事於文字間故來參訪且出其志貞"
    },
    {
        "image_path": "Task_A/a_168.jpg",
        "text": "至元己巳之春宣撫趙公介黄冠師朱德明子玉孟志貞子正來"
    },
    {
        "image_path": "Task_A/a_169.jpg",
        "text": "金大定間賜額曰崇靈左掖太華右抱驪山南挹靈台北瞰渭水"
    },
    {
        "image_path": "Task_A/a_170.jpg",
        "text": "之祠元康中氐人齊萬年反命處征之力戰而歿秦人思而祠之"
    },
    {
        "image_path": "Task_A/a_171.jpg",
        "text": "之狀曰渭南縣治之南一舍而近有觀曰崇靈乃晉將周處子隱"
    },
    {
        "image_path": "Task_A/a_172.jpg",
        "text": "當是頌道士宋□敬導修水利之詩餘甚俚不錄"
    },
    {
        "image_path": "Task_A/a_173.jpg",
        "text": "右詩在觀村老君庵有曰疏通汧渭河千里灌溉岐郿稻萬畞"
    },
    {
        "image_path": "Task_A/a_174.jpg",
        "text": "未見原石不詳尺寸王博文撰文僕散祖英正書在渭南縣"
    },
    {
        "image_path": "Task_A/a_175.jpg",
        "text": "至元甲子縣民孫貴梁進等禮請子玉主持之子玉潁川人幼值"
    },
    {
        "image_path": "Task_A/a_176.jpg",
        "text": "託極力營爲己之利害弗顧也間從士大夫游酒酣耳熱談笑起"
    },
    {
        "image_path": "Task_A/a_177.jpg",
        "text": "移千載爲一朝不同則揆一朝爲千載今關中士民浩浩子玉與"
    },
    {
        "image_path": "Task_A/a_178.jpg",
        "text": "貞之狀茲不再陳所謂慕子隱之風義故居其祠者請擴而論之"
    },
    {
        "image_path": "Task_A/a_179.jpg",
        "text": "勒之貞珉願屬筆於子幸無辭焉予曰子玉之爲人已詳見於志"
    },
    {
        "image_path": "Task_A/a_180.jpg",
        "text": "貞所述如此宣撫公曰子玉之意欲以己之出處與其觀之梗槪"
    },
    {
        "image_path": "Task_A/a_181.jpg",
        "text": "之禮貌非不相際也言語非不相接也而不與之如膠漆之永固"
    },
    {
        "image_path": "Task_A/a_182.jpg",
        "text": "舞忘形忘世人之毁譽弗問也平生慕子隱之風義故居其祠志"
    },
    {
        "image_path": "Task_A/a_183.jpg",
        "text": "源爲全眞師院門旣大敬奉之家衆喪葬所須必齋錄之薦命子"
    },
    {
        "image_path": "Task_A/a_184.jpg",
        "text": "壬辰兵革之際流遇陝右九歲禮丹陽子馬尊師之孫太華李通"
    },
    {
        "image_path": "Task_A/a_185.jpg",
        "text": "夫人之禀性所尙不同同則相親異則相疏無古今之殊也同則"
    },
    {
        "image_path": "Task_A/a_186.jpg",
        "text": "有過門酒食芻粟必令豐厚家之有無不計也善於應物人有所"
    },
    {
        "image_path": "Task_A/a_187.jpg",
        "text": "玉學之子玉性聰頴不朞歲曲盡其能且倜儻灑落喜接賓客人"
    },
    {
        "image_path": "Task_A/a_188.png",
        "text": "聲之轉按莊子達生記消子爲王卷闘雞釋文消本作消惟查"
    },
    {
        "image_path": "Task_A/a_189.png",
        "text": "今以聲相近者衡之買之轉聲爲密朱鉏之合聲爲州杜注買"
    },
    {
        "image_path": "Task_A/a_190.png",
        "text": "此避髙祖諱猶楊淵之稱楊泉非一字泉明也"
    },
    {
        "image_path": "Task_A/a_191.png",
        "text": "周禮內史掌王八枋之法釋文枋本又作柄儀禮士昏禮主人"
    },
    {
        "image_path": "Task_A/a_192.png",
        "text": "哥廣韻古歌字又今呼爲兄"
    },
    {
        "image_path": "Task_A/a_193.png",
        "text": "羣廣韻音膻說文羊臭也○案膻集韻音羶"
    },
    {
        "image_path": "Task_A/a_194.png",
        "text": "說文短字下曰有所長短以矢爲正从矢豆聲段氏曰當云"
    },
    {
        "image_path": "Task_A/a_195.png",
        "text": "渠無千得而莫掩一失之時寧"
    },
    {
        "image_path": "Task_A/a_196.png",
        "text": "是以前代名人每窮斯璺顔之"
    },
    {
        "image_path": "Task_A/a_197.png",
        "text": "寫字之譌隸書偏旁隸字原起"
    },
    {
        "image_path": "Task_A/a_198.png",
        "text": "抗身青雲中網羅孰䏻施觀此則稱青雲者非聖賢"
    },
    {
        "image_path": "Task_A/a_199.png",
        "text": "日史記秦紀他時秦地不過千里又始皇紀異日韓"
    },
    {
        "image_path": "Task_A/a_200.png",
        "text": "通糧道也今廣陵韓江是益城邗句絶溝過江淮自"
    }
]