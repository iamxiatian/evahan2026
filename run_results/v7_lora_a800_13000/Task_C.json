[
  {
    "image_path": "Task_C/c_001.jpg",
    "text": "内聲聲等因奏准行知在柔兹據該署閩道黃芳詳稱美法兩國"
  },
  {
    "image_path": "Task_C/c_002.jpg",
    "text": "六萬九千五百九十二兩三錢七分三厘洋葯税銀六萬四千五"
  },
  {
    "image_path": "Task_C/c_003.jpg",
    "text": "任之日起至十一月十一日止計征各國洋商道出口稅銀二十"
  },
  {
    "image_path": "Task_C/c_004.jpg",
    "text": "洋药稅銀十萬三百十八兩三錢又該署開道自十月初六日維"
  },
  {
    "image_path": "Task_C/c_005.jpg",
    "text": "洋商進出口稅銀四十六萬五千五百六十一兩八錢七分三厘"
  },
  {
    "image_path": "Task_C/c_006.jpg",
    "text": "閩道吴煥任内自閏八月初八日起至十月初五日止計征各國"
  },
  {
    "image_path": "Task_C/c_007.jpg",
    "text": "分六厘又征洋商稅銀十六萬四千八百三十六兩三錢内前官"
  },
  {
    "image_path": "Task_C/c_008.jpg",
    "text": "收各國洋商進出口稅銀七十三萬五千一百五十四兩二錢四"
  },
  {
    "image_path": "Task_C/c_009.jpg",
    "text": "日起至十一月十一日止係外國第九結期滿計江海閩實共征"
  },
  {
    "image_path": "Task_C/c_010.jpg",
    "text": "領事以第九結屈期請照向章核扣查自同治元年閏八月初八"
  },
  {
    "image_path": "Task_C/c_011.jpg",
    "text": "月次咨呈總理各園事物衙門查照并分咨上海欵差大臣天津"
  },
  {
    "image_path": "Task_C/c_012.jpg",
    "text": "其奏伏乞呈上聖鑒謹奏同治二年正月十四日議政王軍機大"
  },
  {
    "image_path": "Task_C/c_013.jpg",
    "text": "通商大臣查核外所有循例具報十月俄國商情緣由理合恭摺"
  },
  {
    "image_path": "Task_C/c_014.jpg",
    "text": "元年十一月二十二日"
  },
  {
    "image_path": "Task_C/c_015.jpg",
    "text": "佳奉旨知道了欽此"
  },
  {
    "image_path": "Task_C/c_016.jpg",
    "text": "叵分别辧理理合恭摺奏聞伏乞聖鑒謹奏同治二年二月初五"
  },
  {
    "image_path": "Task_C/c_017.jpg",
    "text": "錢一厘内應和前項各二成銀一萬三千二百十六兩一錢一分"
  },
  {
    "image_path": "Task_C/c_018.jpg",
    "text": "八厪奴才已令照數刻出派委候補熟巫觀祐解文三口通商大"
  },
  {
    "image_path": "Task_C/c_019.jpg",
    "text": "日議政王軍機大臣奉旨該衙門知道欽此"
  },
  {
    "image_path": "Task_C/c_020.jpg",
    "text": "解水脚銀二萬六百九十五兩一錢六分八厘部飯食銀一萬六"
  },
  {
    "image_path": "Task_C/c_021.jpg",
    "text": "存手餘銀七百六十五兩二錢三分三厘統共應存銀八十三萬"
  },
  {
    "image_path": "Task_C/c_022.jpg",
    "text": "千兩正襍盈餘平餘水脚造辦處備貢等十五兩加平共銀一萬"
  },
  {
    "image_path": "Task_C/c_023.jpg",
    "text": "四百七十兩九錢一分二厘應解造辦處載存備貢舉五萬五"
  },
  {
    "image_path": "Task_C/c_024.jpg",
    "text": "支銀一十四萬八千一百四十五錢七分三厘外尚循例報"
  },
  {
    "image_path": "Task_C/c_025.jpg",
    "text": "百七十五兩解鄂閩稅銀六十二萬七千六百七十四兩一分三"
  },
  {
    "image_path": "Task_C/c_026.jpg",
    "text": "五百六十二两一分六厘造辦處備貢二十五兩加平銀一千三"
  },
  {
    "image_path": "Task_C/c_027.jpg",
    "text": "菆等銀六萬四千五百七十六兩五錢七分三厘以上四款共摺"
  },
  {
    "image_path": "Task_C/c_028.jpg",
    "text": "脚銀三千五百六十四兩支銷通関經費養廉工食及髂鏡折"
  },
  {
    "image_path": "Task_C/c_029.jpg",
    "text": "厘以上六款共存銀七十三萬三千八百七十七兩一錢九厘另"
  },
  {
    "image_path": "Task_C/c_030.jpg",
    "text": "稱貿易團奮有儀國人二十名自十一月初一日走至十一月"
  },
  {
    "image_path": "Task_C/c_031.jpg",
    "text": "充八名涂陸續旋囬人十九名現在貿易園廿有俄國人二十二"
  },
  {
    "image_path": "Task_C/c_032.jpg",
    "text": "曽于十一月二十五日將十月分商情奏明在案孟様委員等呈"
  },
  {
    "image_path": "Task_C/c_033.jpg",
    "text": "准章程內有各國商情按月奏報一除奴才查俄國在伊犁通商"
  },
  {
    "image_path": "Task_C/c_034.jpg",
    "text": "底止由博羅胡吉爾卡倫来貿易人七名来送字人五名并哈薩"
  },
  {
    "image_path": "Task_C/c_035.jpg",
    "text": "照咸臺十一年二月准王大母来咨設立總理各國事務衙門奏"
  },
  {
    "image_path": "Task_C/c_036.jpg",
    "text": "奴才常清䟽奏為循例按月具報俄國商情恭敬仰祈聖鑒事窃"
  },
  {
    "image_path": "Task_C/c_037.jpg",
    "text": "同治二年二月二十日常清奏俄國商情由"
  },
  {
    "image_path": "Task_C/c_038.jpg",
    "text": "今并未旋回等因呈奉前来奴才復加查核均係實在情形堪以"
  },
  {
    "image_path": "Task_C/c_039.jpg",
    "text": "石谷安生理商情靜謐再查俄國巨森倫大臣于六月間出卡至"
  },
  {
    "image_path": "Task_C/c_040.jpg",
    "text": "南北各海口船鈔項下酌提三成由各海關照照三個月一結奏"
  },
  {
    "image_path": "Task_C/c_041.jpg",
    "text": "勧銀四千四兩三錢應解三成銀一千二百一兩二錢几分廈門"
  },
  {
    "image_path": "Task_C/c_042.jpg",
    "text": "之日起和至閏八月初七日底滿第八結止核計福州口共征船"
  },
  {
    "image_path": "Task_C/c_043.jpg",
    "text": "因承准此奴才現已邁照奏案自同治元年七月二十五日奉旨"
  },
  {
    "image_path": "Task_C/c_044.jpg",
    "text": "三成銀两委員辭京嗣後并各按各結委員批辭毋稍進誤各等"
  },
  {
    "image_path": "Task_C/c_045.jpg",
    "text": "元年六月二十五日奉旨之日為始扣至第八結浪滿即将此項"
  },
  {
    "image_path": "Task_C/c_046.jpg",
    "text": "報之期委員批解本衙門支納以資應用行令奴才遵照以同治"
  },
  {
    "image_path": "Task_C/c_047.jpg",
    "text": "奏設立學習外國語言文字學館一切薪水給賞奏蒙允准在予"
  },
  {
    "image_path": "Task_C/c_048.jpg",
    "text": "奴才文清奏再奴才承准總理各國事務衙門行知本衙門具"
  },
  {
    "image_path": "Task_C/c_049.jpg",
    "text": "同治二年三月初五日文清片"
  },
  {
    "image_path": "Task_C/c_050.jpg",
    "text": "為照會事前因本署欽差全權大住總理之任已奉諭旨簡放柏"
  },
  {
    "image_path": "Task_C/c_051.jpg",
    "text": "諸事㫸貴親王及諸住貴大臣無不推誠相待睦䑓久而益衆本"
  },
  {
    "image_path": "Task_C/c_052.jpg",
    "text": "事一切概不預聞惟本大臣承乏愿任數載于茲與貴衙門曾辤"
  },
  {
    "image_path": "Task_C/c_053.jpg",
    "text": "交拍大臣接受此後本署事务均由拍大臣發辦本大臣既經卸"
  },
  {
    "image_path": "Task_C/c_054.jpg",
    "text": "已经人到抵署定于本月三十日接任本大臣謹將閩防文卷移"
  },
  {
    "image_path": "Task_C/c_055.jpg",
    "text": "大臣并率同㳙賛大臣等前來當即照會貴衙門在案並拍大臣"
  },
  {
    "image_path": "Task_C/c_056.jpg",
    "text": "同治二年三月初六日恭親王單法圖照會"
  },
  {
    "image_path": "Task_C/c_057.jpg",
    "text": "也為光縣會貴親王請煩查照湏至照會者"
  },
  {
    "image_path": "Task_C/c_058.jpg",
    "text": "大官銘佩此哀以後無論回國供職或移官他處皆當永矢弗忘"
  },
  {
    "image_path": "Task_C/c_059.jpg",
    "text": "情前来奴才伏查台湾沪尾口通商事宜既經前督臣慶端派委"
  },
  {
    "image_path": "Task_C/c_060.jpg",
    "text": "本年六月二十二日先行啓征應議章程脩容另行會議呈數等"
  },
  {
    "image_path": "Task_C/c_061.jpg",
    "text": "起累闢闘征稅不便遲疑隨即暫借沪尾守備衙署作為稅關于"
  },
  {
    "image_path": "Task_C/c_062.jpg",
    "text": "民呈報英國領事官郁和已移駐沪尾且有洋船停泊口岸應即"
  },
  {
    "image_path": "Task_C/c_063.jpg",
    "text": "值彰化會匯滋事道路梗阻未能剋期會議致稽關辦務掾區天"
  },
  {
    "image_path": "Task_C/c_064.jpg",
    "text": "水廳轄之八里坌即沪尾地方堪以設關征稅祇綠一切事宜適"
  },
  {
    "image_path": "Task_C/c_065.jpg",
    "text": "前往查辯旋據委員區天民會同台灣鎮道府勘定臺灣府屬淡"
  },
  {
    "image_path": "Task_C/c_066.jpg",
    "text": "所有設閩征稅一切事宜先經前督臣慶端派委候補道區天民"
  },
  {
    "image_path": "Task_C/c_067.jpg",
    "text": "奴才文清跪奏再查英法味三國奉准在於台灣海口開市通商"
  },
  {
    "image_path": "Task_C/c_068.jpg",
    "text": "同治二年三月初八日文清片"
  },
  {
    "image_path": "Task_C/c_069.jpg",
    "text": "再屆衙門應夫一切經費自咸豐十年八月起至十一月十二日"
  },
  {
    "image_path": "Task_C/c_070.jpg",
    "text": "項用銀五千二百七十兩九錢七分又支用欵待各國公使臣"
  },
  {
    "image_path": "Task_C/c_071.jpg",
    "text": "年内支用司員稫飯供事酥租并役羙食以及心紅紙張茶燭等"
  },
  {
    "image_path": "Task_C/c_072.jpg",
    "text": "百两又十一年分餘存銀三百二十七兩五錢九分三厘共計領"
  },
  {
    "image_path": "Task_C/c_073.jpg",
    "text": "止達閩共十三個月每月由户部領銀六百兩共領到銀七千八"
  },
  {
    "image_path": "Task_C/c_074.jpg",
    "text": "七两五錢九分三厘具奏在案兹自同治元年正月起至十二月"
  },
  {
    "image_path": "Task_C/c_075.jpg",
    "text": "止支放各數目業于上年十二月間核明除用寔存銀三百二十"
  },
  {
    "image_path": "Task_C/c_076.jpg",
    "text": "酒筍随時稲飯冬月煤炭以及妻并出差川資添買器具刋刻童"
  },
  {
    "image_path": "Task_C/c_077.jpg",
    "text": "八千一百二十七两五錢九分三厘督飭司員核實支放計一"
  },
  {
    "image_path": "Task_C/c_078.jpg",
    "text": "同治二年三月十九日總理各國事務衙門片"
  },
  {
    "image_path": "Task_C/c_079.jpg",
    "text": "核復施行再同治元年祝鑅應請仍飭天津道管理合倂陳明"
  },
  {
    "image_path": "Task_C/c_080.jpg",
    "text": "謹奏同治二年三月二十一日議政王軍機大臣奉旨人部續丟"
  },
  {
    "image_path": "Task_C/c_081.jpg",
    "text": "聖裁涂冶明戶部外理合恭摺具奏伏乞皇太后皇上聖鑒敕部"
  },
  {
    "image_path": "Task_C/c_082.jpg",
    "text": "賠歉并傾鎔折耗外收銀五十三萬六千四百六十七而五錢三"
  },
  {
    "image_path": "Task_C/c_083.jpg",
    "text": "易敢不竭力設籌設司道再三商議掇将江海閩應觧江一半銀"
  },
  {
    "image_path": "Task_C/c_084.jpg",
    "text": "給江西地丁銀三十萬兩委解充餉京師為天下根本慶支吉置"
  },
  {
    "image_path": "Task_C/c_085.jpg",
    "text": "狀之慮此項稅銀自應解回江省籍紆眉急惟前奉行准部添提"
  },
  {
    "image_path": "Task_C/c_086.jpg",
    "text": "分八厘據總局司道詳稱現在邊境戒嚴防軍各軍均有懸詫待"
  },
  {
    "image_path": "Task_C/c_087.jpg",
    "text": "分六厘應行解江一半銀二十六萬八千一百三十三兩七錢六"
  },
  {
    "image_path": "Task_C/c_088.jpg",
    "text": "二月起至同治元年六月底止代征正半各稅涂扣遂異法兩國"
  },
  {
    "image_path": "Task_C/c_089.jpg",
    "text": "秦明以一半解文湖北一半解文江西茲核册造自咸豐十一年"
  },
  {
    "image_path": "Task_C/c_090.jpg",
    "text": "再江海閔代征漢土几江洋稅經總理各國事務衙門會同戶部"
  },
  {
    "image_path": "Task_C/c_091.jpg",
    "text": "同治二年四月十六日沈保植片"
  },
  {
    "image_path": "Task_C/c_092.jpg",
    "text": "摺内将不扣二成之船鈔子稅及土貨平稅詳細聲明以重稅課"
  },
  {
    "image_path": "Task_C/c_093.jpg",
    "text": "銀二十七萬八千五百五十六兩八錢九分五厘按照條約扣交"
  },
  {
    "image_path": "Task_C/c_094.jpg",
    "text": "税亦經分晰聲明各在紫兹同治元年閏八月初八日起至十"
  },
  {
    "image_path": "Task_C/c_095.jpg",
    "text": "住歙清先後恭敬奏報至征收第一至第八結之船鈔及土貨丰"
  },
  {
    "image_path": "Task_C/c_096.jpg",
    "text": "十萬八千二百一十五兩五錢六分六厘經前督佳勞崇光會同"
  },
  {
    "image_path": "Task_C/c_097.jpg",
    "text": "咸豐十年八月十七日起至同治元年閏八月初七日止歷過第"
  },
  {
    "image_path": "Task_C/c_098.jpg",
    "text": "庸兩闕併計等周均經轉行通照匡等查專海閩及潮州新闋自"
  },
  {
    "image_path": "Task_C/c_099.jpg",
    "text": "又粵海閩及潮州新閩稅項于第八結起各歸各閩分別秦報毋"
  },
  {
    "image_path": "Task_C/c_100.jpg",
    "text": "一月十一日止為第九結專漢大閩征収各國進出口貨正稅世"
  },
  {
    "image_path": "Task_C/c_101.jpg",
    "text": "一至第八結在征欵正稅内共扣交英法兩國谷二成銀一百二"
  },
  {
    "image_path": "Task_C/c_102.jpg",
    "text": "年八月二十七日起至十月二十六日止連閏計三個月福州口"
  },
  {
    "image_path": "Task_C/c_103.jpg",
    "text": "銀數目謹附片陳明伏乞聖鑒謹奏同治二年五月初二日議政"
  },
  {
    "image_path": "Task_C/c_104.jpg",
    "text": "并分咨查照外合将福厦二口底三個月征政各國洋商洋药稅"
  },
  {
    "image_path": "Task_C/c_105.jpg",
    "text": "稅銀六萬二千六百三十六兩六錢八分六厘除另行造册載銷"
  },
  {
    "image_path": "Task_C/c_106.jpg",
    "text": "銀一萬九千二十二兩三錢八分六厘合計稿廈二口共征洋藥"
  },
  {
    "image_path": "Task_C/c_107.jpg",
    "text": "共征洋藥稅銀四萬三千六百十四兩三錢廈門口共征洋藥稅"
  },
  {
    "image_path": "Task_C/c_108.jpg",
    "text": "奴才將每屆三個月征收銀兩数目先後奏摺在案今自同治元"
  },
  {
    "image_path": "Task_C/c_109.jpg",
    "text": "奴才文清跪奏再福廈二口所征各國洋商進口洋葯稅銀業經"
  },
  {
    "image_path": "Task_C/c_110.jpg",
    "text": "同治二年五月初二日文清片"
  },
  {
    "image_path": "Task_C/c_111.jpg",
    "text": "王軍機大佳奉旨該衙知道欽此"
  },
  {
    "image_path": "Task_C/c_112.jpg",
    "text": "税則先行征收仍照舊彙解藩庫充餉一面咨部查照理合會同"
  },
  {
    "image_path": "Task_C/c_113.jpg",
    "text": "二年五月十七日議政王軍機大臣奉旨該衙門知道片二件并"
  },
  {
    "image_path": "Task_C/c_114.jpg",
    "text": "三口通商大往崇厚恭摺具奏伏乞皇太后皇上聖鑒謹奏同治"
  },
  {
    "image_path": "Task_C/c_115.jpg",
    "text": "一各関所收稅銀于本年六月十七日即英國八月初一日起先"
  },
  {
    "image_path": "Task_C/c_116.jpg",
    "text": "年之内俱照此辦理"
  },
  {
    "image_path": "Task_C/c_117.jpg",
    "text": "赴銀號支領倘銀有未交由李總稅務司即于稅餉徑扣抵用四"
  },
  {
    "image_path": "Task_C/c_118.jpg",
    "text": "備此項輪船經費按照所定本月所定之数由李總稅務司派人"
  },
  {
    "image_path": "Task_C/c_119.jpg",
    "text": "臣李鴻章恭摺具陳伏乞皇太后皇上聖鑒謹奏同治二年五月"
  },
  {
    "image_path": "Task_C/c_120.jpg",
    "text": "明總理各國事务衙門外任等謹會同署理欽差大臣江蘇巡撫"
  },
  {
    "image_path": "Task_C/c_121.jpg",
    "text": "稅現尚無征收應候續有征存再行開報除造册送部查核并咨"
  },
  {
    "image_path": "Task_C/c_122.jpg",
    "text": "或照舊例蓬閣納稅或照新例納子口稅原聽商自使其子口"
  },
  {
    "image_path": "Task_C/c_123.jpg",
    "text": "前已由閔擇地開設惟現無洋商自運洋貨前入内地其置買土"
  },
  {
    "image_path": "Task_C/c_124.jpg",
    "text": "两四錢土貨丰税銀九千一百二十二兩二錢八分又子口總卡"
  },
  {
    "image_path": "Task_C/c_125.jpg",
    "text": "銀六千七十二兩五分三厘潮州新関船鈔銀二千五百六十五"
  },
  {
    "image_path": "Task_C/c_126.jpg",
    "text": "大閩共收不扣二成之船鈔銀四千八百十几兩二錢土貨半稅"
  },
  {
    "image_path": "Task_C/c_127.jpg",
    "text": "一月十二日起至二年二月十三日止三個月第十結期内患"
  },
  {
    "image_path": "Task_C/c_128.jpg",
    "text": "八兩四錢嗣後仍當按結清算以符條約至本年底同治元年十"
  },
  {
    "image_path": "Task_C/c_129.jpg",
    "text": "洋葯免單銀四十九百四十五兩五錢共征洋稅銀三萬五千二"
  },
  {
    "image_path": "Task_C/c_130.jpg",
    "text": "分贊征第十一結進口正稅及洋葯稅共銀二萬三千二百二十"
  },
  {
    "image_path": "Task_C/c_131.jpg",
    "text": "兩三分七厘內除免單半稅船鈔不扣二成外實征第十結進口"
  },
  {
    "image_path": "Task_C/c_132.jpg",
    "text": "百七十一兩三錢七厘兩結總共征收洋稅銀三萬八千七百四"
  },
  {
    "image_path": "Task_C/c_133.jpg",
    "text": "九兩八錢進口正稅免單銀二千八百四十七兩八錢五分四厘"
  },
  {
    "image_path": "Task_C/c_134.jpg",
    "text": "稅銀二千八百八十四兩六錢一分三厘船鈔銀一千三百六十"
  },
  {
    "image_path": "Task_C/c_135.jpg",
    "text": "一百六十四两八錢一分八厘洋藥銀六百六十兩復進口半"
  },
  {
    "image_path": "Task_C/c_136.jpg",
    "text": "正稅及洋葦稅共銀三百四十三兩八錢計應扣送英法兩國各"
  },
  {
    "image_path": "Task_C/c_137.jpg",
    "text": "出口正稅銀一千三百九十八兩七錢二分二厘出口稅銀二萬一"
  },
  {
    "image_path": "Task_C/c_138.jpg",
    "text": "二成銀六十八兩七錢六分共應扣撥銀一百三十七兩五錢二"
  },
  {
    "image_path": "Task_C/c_139.jpg",
    "text": "第十一結征稅扣文英法兩國各二成銀并下餘銀兩撥解鎮營"
  },
  {
    "image_path": "Task_C/c_140.jpg",
    "text": "陳伏乞聖鑒謹奏同治二年七月初二日議政王軍機大臣奉旨"
  },
  {
    "image_path": "Task_C/c_141.jpg",
    "text": "軍餉各緣由理合會同協辯大學士兩江總督桂潛國藩附片具"
  },
  {
    "image_path": "Task_C/c_142.jpg",
    "text": "解到同文館經費銀兩照數充政存俟便員搭解外所有鎭江閔"
  },
  {
    "image_path": "Task_C/c_143.jpg",
    "text": "数往来洋船数司各清册赶造分送備查并飭蘇藩司將鎭江閔"
  },
  {
    "image_path": "Task_C/c_144.jpg",
    "text": "該衙門知道敍此"
  },
  {
    "image_path": "Task_C/c_145.jpg",
    "text": "同治二年七月二十五日恭親王等奏遵議沈保楨奏請創"
  },
  {
    "image_path": "Task_C/c_146.jpg",
    "text": "豐十年三月二十六日起至十一年三月二十三日止代征縣門"
  },
  {
    "image_path": "Task_C/c_147.jpg",
    "text": "數撥充江忠義席賢全兩軍月餉此外別無可撿惟查沪閩自咸"
  },
  {
    "image_path": "Task_C/c_148.jpg",
    "text": "几江閣撥銀三萬兩以清欵項當以該閣所收洋稅紹怪奏明儘"
  },
  {
    "image_path": "Task_C/c_149.jpg",
    "text": "門否贄辨輪船經總稅務司李泰國向英國借銀十五萬兩酌定"
  },
  {
    "image_path": "Task_C/c_150.jpg",
    "text": "一片奉貢該衙門謙奏欽此據原奏內稱前准總理各國事務衙"
  },
  {
    "image_path": "Task_C/c_151.jpg",
    "text": "輪船我價銀三萬兩擬請在上海應行解運贍閩絲稅銀內劃撥"
  },
  {
    "image_path": "Task_C/c_152.jpg",
    "text": "二年七月初六日軍機處交出陝西巡撫沈保猶奏九江閩奉強"
  },
  {
    "image_path": "Task_C/c_153.jpg",
    "text": "總理各國事務稱碩恭親王臣奕訢等跪奏爲遵旨議奏事同治"
  },
  {
    "image_path": "Task_C/c_154.jpg",
    "text": "撥九江閣輪船我價銀兩由"
  },
  {
    "image_path": "Task_C/c_155.jpg",
    "text": "同治二年八月初二日阿克敦布等片"
  },
  {
    "image_path": "Task_C/c_156.jpg",
    "text": "章辦理該俄羅斯官兵二員名經該差章京根布扎布已于二十"
  },
  {
    "image_path": "Task_C/c_157.jpg",
    "text": "呈報前來當經飛飪張家口管站部員并照會前途地方各官瞧"
  },
  {
    "image_path": "Task_C/c_158.jpg",
    "text": "該管站鄰員按照章程出派該管章京棉布扎布樣替送口等因"
  },
  {
    "image_path": "Task_C/c_159.jpg",
    "text": "協理台吉車林多爾濟等伴送於七月二十九日行抵賽爾烏蘇"
  },
  {
    "image_path": "Task_C/c_160.jpg",
    "text": "三日護送至口即于二十三日由張家口署管站部員恩林出派"
  },
  {
    "image_path": "Task_C/c_161.jpg",
    "text": "稱今有俄國差官格哩宻喲諾布一員兵一名赴京由庫倫出派"
  },
  {
    "image_path": "Task_C/c_162.jpg",
    "text": "再昨于七月二十三日奴才等接據賽爾烏蘇營站部員松壽報"
  },
  {
    "image_path": "Task_C/c_163.jpg",
    "text": "事務衙門并咨行兵部理藩院查照外理合循案附片奏聞為此"
  },
  {
    "image_path": "Task_C/c_164.jpg",
    "text": "該感謝蒙古恭頌額爾海呢等一併護送進京訖除咨呈總理各國"
  },
  {
    "image_path": "Task_C/c_165.jpg",
    "text": "日廷歷過第一至第十縉在征收正稅內共扣交英法兩國二成"
  },
  {
    "image_path": "Task_C/c_166.jpg",
    "text": "七十二兩四錢二分五厘按照條約扣交二成應交英法兩國各"
  },
  {
    "image_path": "Task_C/c_167.jpg",
    "text": "一結粵海大閱征收各國進出口貨正稅共銀二十萬二千二百"
  },
  {
    "image_path": "Task_C/c_168.jpg",
    "text": "各在案兹自同治二年二月十四日起至五月十五日止為第十"
  },
  {
    "image_path": "Task_C/c_169.jpg",
    "text": "至征收第一至第十結之船鈔及土貸茅稅銀數亦經分晰聲明"
  },
  {
    "image_path": "Task_C/c_170.jpg",
    "text": "銀一百三十九萬二千七百八十八両四錢業經先後恭摺奏報"
  },
  {
    "image_path": "Task_C/c_171.jpg",
    "text": "反潮州新聞自咸豐十年八月廿七日起至同治二年二月十三"
  },
  {
    "image_path": "Task_C/c_172.jpg",
    "text": "各閣分別奏毋庸兩閣併計等固均經轉行遵照呈等查寶江海関"
  },
  {
    "image_path": "Task_C/c_173.jpg",
    "text": "細聲明以重稅課又粤海閩并潮州新関税項於第八結起谷薦"
  },
  {
    "image_path": "Task_C/c_174.jpg",
    "text": "奏報正稅扣二成摺内将不扣二成之船鈔子税及土貨半稅詳"
  },
  {
    "image_path": "Task_C/c_175.jpg",
    "text": "二十几日開辨即設立正副稅務司并外國冩字及杆子手通事"
  },
  {
    "image_path": "Task_C/c_176.jpg",
    "text": "云稅務司經費自第一結起也臣等業已飭令赫德自開辯起截"
  },
  {
    "image_path": "Task_C/c_177.jpg",
    "text": "支清摺内自第一結閉轂者係因和約換後扣還喪法兩國五分"
  },
  {
    "image_path": "Task_C/c_178.jpg",
    "text": "報而潮州新閩亦于是年十二月初九日由省前往開辦議設稅"
  },
  {
    "image_path": "Task_C/c_179.jpg",
    "text": "持有五口通商大臣扎諭來粤在前任監督恆祺任于九年九月"
  },
  {
    "image_path": "Task_C/c_180.jpg",
    "text": "之一以第一結起即將各海關稅務司經費順序按結開列并非"
  },
  {
    "image_path": "Task_C/c_181.jpg",
    "text": "務司人等閩港立閩征祝其赫德呈報總理衙門呈海潮州関狀"
  },
  {
    "image_path": "Task_C/c_182.jpg",
    "text": "言及甫經試辦一切需用人等經費多寡尚難預定是以暫緩奏"
  },
  {
    "image_path": "Task_C/c_183.jpg",
    "text": "奉硃批知遇了歘此欽遵有案其時不及奏請經費者因稅務司"
  },
  {
    "image_path": "Task_C/c_184.jpg",
    "text": "人等部同收稅當經前會勞崇光於是年十二月間隔片委明"
  },
  {
    "image_path": "Task_C/c_185.jpg",
    "text": "等固所有八九十等結期内應解三成船鈔銀兩業經前任將軍"
  },
  {
    "image_path": "Task_C/c_186.jpg",
    "text": "千一百二十六兩五分以上福州廈門二口共征船鈔銀八千五"
  },
  {
    "image_path": "Task_C/c_187.jpg",
    "text": "分廈門口共征船嵗銀三千七百五十三兩五錢應解三成銀一"
  },
  {
    "image_path": "Task_C/c_188.jpg",
    "text": "征船鈔銀四千八百六錢應解三成銀一千四百四十兩一錢八"
  },
  {
    "image_path": "Task_C/c_189.jpg",
    "text": "二月十四日起至五月十五日在滿第十一結止核計福州□共"
  },
  {
    "image_path": "Task_C/c_190.jpg",
    "text": "臣文清及奴才按結委員批解并附片奏明在案今自同治二年"
  },
  {
    "image_path": "Task_C/c_191.jpg",
    "text": "成銀兩按結委員醉京以應學習外國語言文字學館薪水經費"
  },
  {
    "image_path": "Task_C/c_192.jpg",
    "text": "衙門分知應自同治元年七月二十五日奉旨之日為始酌提三"
  },
  {
    "image_path": "Task_C/c_193.jpg",
    "text": "奴才覺羅耆齡跪奏再查閩海閩征收船鈔前准總理各國事務"
  },
  {
    "image_path": "Task_C/c_194.jpg",
    "text": "同治二年八月二十日耆齡片"
  },
  {
    "image_path": "Task_C/c_195.jpg",
    "text": "科書役截暍三項銀兩留閨犒賞并辤公路賈零星等事之用不"
  },
  {
    "image_path": "Task_C/c_196.png",
    "text": "畫鶯局候諸君子轅下乎季"
  },
  {
    "image_path": "Task_C/c_197.png",
    "text": "重忠孝人也太公老矣橘之强"
  },
  {
    "image_path": "Task_C/c_198.png",
    "text": "則跽杖則杖官俸所入半以衣"
  },
  {
    "image_path": "Task_C/c_199.png",
    "text": "食五宗及落魄谁何之游士不"
  },
  {
    "image_path": "Task_C/c_200.png",
    "text": "矜其能不伐其徳不驕語負勝"
  }
]